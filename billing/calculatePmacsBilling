#  "BenNumber": "400-4452-4-571661-5340-2810-2992",
#  "FundName": "R01 AG056014",
#  "iLabServiceRequestId": "4334346",
#  "AllocationPercent": 30.0,
#  "BackedupTotalTerabyesUsed": 0.207216796875,
#  "NonBackedupTotalTerabytesUsed": 0,
#  "PmacsBackedupPricePerTeraBytePerYear": 360.0,
#  "PmacsNonBackedupPricePerTeraBytePerYear": 120.0,
#  "BscPmacsStorageCharge": 74.598046875,
#  "BscBill": 111.89707031249999,
#  "AllocatedBscBill": 33.56912109375
# }
#

function allocatePmacsStorageCosts {
    local FwLibDir="$1"
    local BscPmacsStorageOverheadPercent="$2"
    local PmacsBackedupPricePerTeraBytePerYear="$3"
    local PmacsNonBackedupPricePerTeraBytePerYear="$4"
    local ProjectStorageAndAlloctationJsonFile="$5"

    Jq='
          include "FwLib";

          to_entries[]
             | (.key) as $ProjectPath
             | .value
	     | ( backedupTotalTerabytesUsed( .TerabytesUsed ) ) as $BackedupTotalTerabytesUsed
	     | ( nonBackedupTotalTerabytesUsed( .TerabytesUsed ) ) as $NonBackedupTotalTerabytesUsed
	     | ( $BackedupTotalTerabytesUsed + $NonBackedupTotalTerabytesUsed) as $TotalTerabytesUsed
	     | if (($TotalTerabytesUsed > 0) and (. | has("AllocationInfo"))) then
                   .AllocationInfo[]
	         | (
	               if ($BackedupTotalTerabytesUsed > 0.0) then
	       	          $PmacsBackedupPricePerTeraBytePerYear
		       else
		          $PmacsNonBackedupPricePerTeraBytePerYear
		       end
	           ) as $PmacsChargePerTbPerYear
		 | ( $PmacsChargePerTbPerYear * $BscPmacsStorageOverheadPercent) as $BscChargePerTbPerYear
	         | ($TotalTerabytesUsed * ($BscChargePerTbPerYear/12)) as $BscBill
	         | ($TotalTerabytesUsed * ($PmacsChargePerTbPerYear/12)) as $PmacsBill
	         | {
	                "ProjectPath": $ProjectPath
	              , "BenNumber": .BenNumber
	              , "FundName": .FundName
	              , "iLabServiceRequestId": (.iLabServiceRequestId | tostring | sub("\\..$"; ""))
	              , "AllocationPercent": .AllocationPercent
		      , "TotalTerabytesUsed": $TotalTerabytesUsed
		      , "PmacChargePerTbPerYear": $PmacsChargePerTbPerYear
	              , "BscChargePerTbPerYear": $BscChargePerTbPerYear
	              , "BscBill": $BscBill
		      , "AllocatedBscBill": ((.AllocationPercent/100.0) * $BscBill)
		      , "AllocatedPmacsBill": ((.AllocationPercent/100.0) * $PmacsBill)
		      , "AllocatedTerabytesUsed": ((.AllocationPercent/100.0) * $TotalTerabytesUsed)
	           }
               else
                      # $ProjectPath + " no billing allocation"
	              empty
               end
    '

    jq -L "$FwLibDir"											\
       --argjson BscPmacsStorageOverheadPercent "$BscPmacsStorageOverheadPercent"			\
       --argjson PmacsBackedupPricePerTeraBytePerYear "$PmacsBackedupPricePerTeraBytePerYear"		\
       --argjson PmacsNonBackedupPricePerTeraBytePerYear "$PmacsNonBackedupPricePerTeraBytePerYear"	\
           "$Jq" "$ProjectStorageAndAlloctationJsonFile"

}

function convertJsonToCsv {
    local iLabBscPmacsClusterChargesJsonFile="$1"

    local Jq

    Jq='
            input as $Input
	  | 
          (
	    [
	        $Input | to_entries[].key
	    ] | @csv
	  ) as $Headers
	| $Headers,
	  ($Input, inputs | [.[] ] | @csv)
    ' 

    jq -r -n "$Jq" "$iLabBscPmacsClusterChargesJsonFile"
}

#
# reformat json invoices for ilab
# {
#  "ProjectPath": "/project/hippogang",
#  "BenNumber": "400-4452-4-571661-5340-2810-2992",
#  "FundName": "R01 AG056014",
#  "iLabServiceRequestId": "4334346",
#  "AllocationPercent": 30.0,
#  "TotalTerabytesUsed": 0.207216796875,
#  "BscChargePerTbPerYear": 180,
#  "BscBill": 3.108251953125,
#  "AllocatedBscBill": 0.9324755859374999
# }
#
# to
#
# {
#  "service_id": "484515",
#  "note": "R01 AG056014 (400-4452-4-571661-5340-2810-2992) - /project/hippogang - 0.2072 * $15/Tb/M = $3.11 * 0.3% = ",
#  "service_quantity": "0.93",
#  "price": "",
#  "purchased_on": "20260601",
#  "service_request_id": "4334346",
#  "owner_email": "",
#  "pi_email_or_group_id": "",
#  "payment_number": ""
# }
#
function storageInvoiceToIlabCharges {
    local FwLibDir="$1"
    local MinimumCharge="$2"
    local PurchaseDate="$3"
    local BscPmacsStorageInvoicesJsonFile="$4"

    # PMACS storage service id
    local service_id='484515'

    local Jq1
    local Jq2

    Jq1='
        include "FwLib";

        if (.AllocatedBscBill < $MinimumCharge) then
              .ProjectPath
            + ": AllocatedBscBill, "
            + ( .AllocatedBscBill | scale(4))
            + ", is less than minimum charge of "
            + ($MinimumCharge | scale(2))
            | debug | empty
        else
            .
        end
    '

    Jq2='
        include "FwLib";
    
          (. | formatIlabNote) as $IlabNote
        | {
              "service_id": $service_id
            , "note": $IlabNote
	    , "service_quantity": (.AllocatedBscBill | scale(2))
            , "price": ""
            , "purchased_on": $PurchaseDate
            , "service_request_id": (.iLabServiceRequestId | tostring)
            , "owner_email": ""
            , "pi_email_or_group_id": ""
            , "payment_number": ""
        }
    '

    jq -L "$FwLibDir" --argjson MinimumCharge "$MinimumCharge" "$Jq1" "$BscPmacsStorageInvoicesJsonFile" | jq -r -L "$FwLibDir" -r --argjson PurchaseDate "\"$PurchaseDate\"" --argjson service_id "\"$service_id\"" "$Jq2"
}


CsvTotals=$(sys calculatePmacsReportTotals "${InputFiles[@]}")
if [ "$?" -ne 0 ]
then
	echo "${CmdName}: calculatePmacsReportTotals failed" 1>&2
	exit
fi
	
PmacsProjectReportJsonFile="${TmpDir}/PmacsProjectReport.json"
sys convertPmacsCsvReportsToJson "${InputFiles[@]}" > "$PmacsProjectReportJsonFile"
if [ "$?" -ne 0 ]
then
	echo "${CmdName}: convertPmacsCsvReportsToJson failed" 1>&2
	exit
fi
	
NotBackedupIndexJsonFile="${TmpDir}/NotBackedupIndex.json"
sys indexNotBackedupProjects "$PmacsProjectReportJsonFile" > "$NotBackedupIndexJsonFile"
if [ "$?" -ne 0 ]
then
	echo "${CmdName}: indexNotBackedupProjects failed" 1>&2
	exit
fi
	
ProjectItemizedPmacsStorageJsonFile="${TmpDir}/ProjectItemizedStorage.json"
sys itemizeProjectPmacsStorage "$NotBackedupIndexJsonFile" "$PmacsProjectReportJsonFile" > "$ProjectItemizedPmacsStorageJsonFile"
if [ "$?" -ne 0 ]
then
	echo "${CmdName}: itemizeProjectPmacsStorage failed" 1>&2
	exit
fi

ProjectBillingAllocationInfoJsonFile="${TmpDir}/ProjectBillingAllocation.json"
sys createProjectBillingAllocationJson "$BillingAllocationFileName" "$ProjectItemizedPmacsStorageJsonFile" > "$ProjectBillingAllocationInfoJsonFile"
if [ "$?" -ne 0 ]
then
	echo "${CmdName}: createProjectBillingAllocationJson failed" 1>&2
	exit
fi

ProjectStorageAndAllocationJsonFile="${TmpDir}/ProjectStorageAndAllocation.json"
sys jq -s 'reduce .[] as $item ({}; . * $item)' "$ProjectItemizedPmacsStorageJsonFile" "$ProjectBillingAllocationInfoJsonFile" > "$ProjectStorageAndAllocationJsonFile"
if [ "$?" -ne 0 ]
then
	echo "${CmdName}: Reduce ProjectBillingAllocation failed" 1>&2
	exit
fi

TotalStoragePoolsJsonFile="${TmpDir}/TotalStoragePools.json"
sys totalPmacsStoragePools "$ProjectItemizedPmacsStorageJsonFile" > "$TotalStoragePoolsJsonFile"
if [ "$?" -ne 0 ]
then
	echo "${CmdName}: totalPmacsStoragePools failed" 1>&2
	exit
fi

JsonTotals=$(sys jq -L "$FwLibDir" -r '
        include "FwLib";

        [
	      ((.BackedupGPFS + .NotBackedupGPFS) | scale(4))
	    , ((.Backedupbscfiles1 + .NotBackedupbscfiles1) | scale(4))
	    , ((.Backedupbscfiles2 + .NotBackedupbscfiles2) | scale(4))
	    , ((.Backedupbscfiles3 + .NotBackedupbscfiles3) | scale(4))
            , ((
	            .BackedupGPFS
		  + .NotBackedupGPFS
		  + .Backedupbscfiles1
		  + .NotBackedupbscfiles1
		  + .Backedupbscfiles2 
		  + .NotBackedupbscfiles2
		  + .Backedupbscfiles3
		  + .NotBackedupbscfiles3
              ) | scale(4))
            , .ProjectCount

        ] | @csv
    ' "$TotalStoragePoolsJsonFile"
)
if [ "$?" -ne 0 ]
then
	echo "${CmdName}: JsonTotals failed" 1>&2
	exit
fi

BscPmacsStorageInvoicesJsonFile="${TmpDir}/BscPmacsStorageInvoices.json"
sys allocatePmacsStorageCosts "$FwLibDir"							\
          	"$BscPmacsStorageOverheadPercent"						\
		"$PmacsBackedupPricePerTeraBytePerYear"						\
		"$PmacsNonBackedupPricePerTeraBytePerYear"					\
		"$ProjectStorageAndAllocationJsonFile" > "$BscPmacsStorageInvoicesJsonFile"
if [ "$?" -ne 0 ]
then
	echo "${CmdName}: allocatePmacsStorageCosts failed" 1>&2
	exit
fi

#
# service_id,note,service_quantity,price,purchased_on,service_request_id,owner_email,pi_email_or_group_id,payment_number
# 484515,"R01 AG056014 (400-4452-4-571661-5340-2810-2992) - /project/hippogang - .2072TB * $45.00/TB/M = $9.32 * 30% = ",
#2.79,,20260501,4334346
#

iLabBscPmacsClusterChargesJsonFile="${TmpDir}/iLabBscPmacsClusterCharges.json"
sys storageInvoiceToIlabCharges "$FwLibDir" "$MinimumCharge" "$PurchaseDate" "$BscPmacsStorageInvoicesJsonFile" > "$iLabBscPmacsClusterChargesJsonFile"
if [ "$?" -ne 0 ]
then
	echo "${CmdName}: storageInvoiceToIlabCharges failed" 1>&2
	exit
fi

iLabBscPmacsClusterChargesCsvFile="${TmpDir}/${Year}-${Month}-iLabBscPmacsClusterCharges.csv"
sys convertJsonToCsv "$iLabBscPmacsClusterChargesJsonFile" > "$iLabBscPmacsClusterChargesCsvFile"
if [ "$?" -ne 0 ]
then
	echo "${CmdName}: convertJsonToCsv failed" 1>&2
	exit
fi

echo "$CsvTotals" 1>&2
echo "$JsonTotals" 1>&2

jq -s 'reduce .[] as $i (
{
      "AllocatedBscBill": 0
    , "AllocatedPmacsBill": 0
    , "TotalTerabytesUsed": 0
};
{
      "AllocatedPmacsBill": (.AllocatedPmacsBill + $i.AllocatedPmacsBill)
    , "AllocatedBscBill": (.AllocatedBscBill + $i.AllocatedBscBill)
    , "AllocatedTerabytesUsed": (.AllocatedTerabytesUsed + $i.AllocatedTerabytesUsed)
}
)' "$BscPmacsStorageInvoicesJsonFile" 1>&2
if [ "$?" -ne 0 ]
then
	echo "${CmdName}: Total Allocated Sums failed" 1>&2
	exit
fi

