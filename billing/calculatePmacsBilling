#!/bin/bash

CmdName=$(basename "$0")
Syntax="${CmdName} [-d day][-m month][-n][-v][-y year] PmacsReports.csv"
#
# calculatePmacsBilling -m 06 ~/Downloads/project*report*.txt
#
PurchaseDate="${Year}${Month}${Day}"
MinimumCharge='0.01'
BscPmacsStorageOverheadPercent='1.50'
PmacsBackedupPricePerTeraBytePerYear='360.0'
PmacsNonBackedupPricePerTeraBytePerYear='120.0'
ProjectRoot='/project'
NotBackedupFileName='_This_Directory_Tree_Is_Not_Backed_Up_'
BillingAllocationFileName='BillingAllocation.csv'

while getopts 'd:m:nvy:' arg
do
	case "$arg" in 
		d|m|n|v|y)
			eval "opt_${arg}='${OPTARG:=1}'"
			;;
	esac
done

shift $(( "$OPTIND" - 1 ))


InputFiles=( "$@" )

Day='01'
[ -n "$opt_d" ] && Day="$opt_d"

Month=$(date +%m)
[ -n "$opt_m" ] && Month="$opt_m"

Year=$(date +%Y)
[ -n "$opt_y" ] && Year="$opt_y"

TmpDir=/tmp/PmacsBilling

FwDir=$(dirname $(dirname $(which "$0")))
FwLibDir="${FwDir}/lib"

# *** /project is the root of the project paths - one variable please



function sys {
	 [ -n "${opt_n}${opt_v}" ] && echo "$@" 1>&2
	 [ -n "$opt_z" ] || "$@"
}

[ -e "$TmpDir" ] || sys mkdir -p "$TmpDir"

function calculatePmacsReportTotals {
    local InputFiles=( "$@" )

    AwkScript='
            BEGIN {
                Gpfs = 0;
                BscFiles1 = 0;
		    	        BscFiles2 = 0;
    	        Bscfiles3 = 0;
    	        Count = 0
            } ;

            {
                if ($2 == "GPFS") {
    	           Gpfs = Gpfs + ($1 / 1024)
    	        };
    	        if ($2 == "bscfiles1") {
    	           BscFiles1 = BscFiles1 + ($1 / 1024)
    	        } ;
    	        if ($2 == "bscfiles2") {
       	           BscFiles2 = BscFiles2 + ($1 / 1024)
    	        } ;
    	        if ($2 == "bscfiles3") {
    	           BscFiles3 = BscFiles3 + ($1 / 1024)
    	        } ;

                Count = Count + 1
            } ;

            END {
	        printf("%s,%s,%s,%s,%s,%s\n", "GpfsTb", "BscFiles1Tb", "BscFiles2Tb", "BscFiles3Tb", "TotalStorageTb", "ProjectCount");
                printf("%.4f,%.4f,%.4f,%.4f,%.4f,%d\n", Gpfs, BscFiles1, BscFiles2, BscFiles3, Gpfs + BscFiles1 + BscFiles2 + BscFiles3, Count);
            }
    '

    (
          grep '^# NAME' "${InputFiles[0]}" | dos2unix;
          grep -h -v '^#' "${InputFiles[@]}" | grep -v '^$' | dos2unix;
    ) | csvcut -t -c "Size in gb",SERVER | tail -n +2 | awk -F , "$AwkScript"
}

function convertPmacsCsvReportsToJson {
    local InputFiles=( "$@" )

    (
        grep '^# NAME' "${InputFiles[0]}" | dos2unix;
        grep -h -v '^#' "${InputFiles[@]}" | grep -v '^$' | dos2unix
    ) | csvcut -t -c "# NAME","Size in gb","SERVER" | csvjson | jq . 
}

#
# Find non-backed up projects
#
function indexNotBackedupProjects {
    local PmacsProjectReportJsonFile="$1"

    while read ProjectLabel
    do
        ProjectPath="${ProjectRoot}/${ProjectLabel}"
        NotBackedupFile="${ProjectPath}/${NotBackedupFileName}"
        [ -e "$NotBackedupFile" ] && echo "{ \""${ProjectPath}"\": true }"
    done < <(jq -r '.[]["# NAME"]' "$PmacsProjectReportJsonFile" | sort -u) | jq -s 'add'
}

function itemizeProjectPmacsStorage {
    local NotBackedupIndexJsonFile="$1"
    local PmacsProjectReportJsonFile="$2"

    local Jq

    Jq='
         .[]
       | ($ProjectRoot + "/" + .["# NAME"]) as $ProjectPath
       | ($NotBackedupIndex[] | has($ProjectPath) | not) as $Backedup
       | ( if ($Backedup) then "Backedup" else "NotBackedup" end) as $Prefix 
       | {
           ($ProjectPath): {
               "TerabytesUsed": {
                     "BackedupGPFS": (if (.SERVER == "GPFS" and $Backedup) then (.["Size in gb"] / 1024) else 0 end )
	           , "Backedupbscfiles1": (if (.SERVER == "bscfiles1" and $Backedup) then (.["Size in gb"] / 1024) else 0 end )
    	           , "Backedupbscfiles2": (if (.SERVER == "bscfiles2" and $Backedup) then (.["Size in gb"] / 1024) else 0 end )
    	           , "Backedupbscfiles3": (if (.SERVER == "bscfiles3" and $Backedup) then (.["Size in gb"] / 1024) else 0 end )

	           , "NotBackedupGPFS": (if (.SERVER == "GPFS" and ($Backedup == false)) then (.["Size in gb"] / 1024) else 0 end )
	           , "NotBackedupbscfiles1": (if (.SERVER == "bscfiles1" and ($Backedup == false)) then (.["Size in gb"] / 1024) else 0 end )
    	           , "NotBackedupbscfiles2": (if (.SERVER == "bscfiles2" and ($Backedup == false)) then (.["Size in gb"] / 1024) else 0 end )
    	           , "NotBackedupbscfiles3": (if (.SERVER == "bscfiles3" and ($Backedup == false)) then (.["Size in gb"] / 1024) else 0 end )
                }
	    }
         }
    ' 
    jq --argjson ProjectRoot "\"$ProjectRoot\"" --slurpfile NotBackedupIndex "$NotBackedupIndexJsonFile" "$Jq" "$PmacsProjectReportJsonFile" | jq -s 'add' 
}


#
# Pull all the projects out of the ProjectMetrics file.
# for each Project
#    Verify there is a BillingAllocation file
#    Make sure the allocations add to 100%
#    Create json entry in the form
# {
#   "/project/hippogang": {
#     "AllocationInfo": [
#       {
#         "AllocationPercent": 30.0,
#         "iLabServiceRequestId": 4334346.0,
#         "BenNumber": "400-4452-4-571661-5340-2810-2992",
#         "FundName": "R01 AG056014",
#         "BaName": "Bonna Mean",
#         "BaEmail": "Bonna.Mean@pennmedicine.upenn.edu"
#       },
#       {
#         "AllocationPercent": 30.0,
#         "iLabServiceRequestId": 4329982.0,
#         "BenNumber": "400-4452-4-589891-5340-2810-2992",
#         "FundName": "R01 AG069474",
#         "BaName": "Bonna Mean",
#         "BaEmail": "Bonna.Mean@pennmedicine.upenn.edu"
#       },
#       {
#         "AllocationPercent": 40.0,
#         "iLabServiceRequestId": 5040001.0,
#         "BenNumber": "400-4322-4-502965-5340-2810-2992",
#         "FundName": "P30 AG010124",
#         "BaName": "Bonna Mean",
#         "BaEmail": "Bonna.Mean@pennmedicine.upenn.edu"
#       }
#     ]
#   }
# }
# 
#
function createProjectBillingAllocationJson {
    local BillingAllocationFileName="$1"
    local PmacsProjectMetricsJsonFile="$2"

    local ProjectPath
    local BillingAllocationFile
    local AllocationInfoJson
    local TotalAllocationPercent
    local AllocationPercents

    while read ProjectPath
    do
	# [ -n "$opt_v" ] && echo "$ProjectPath" 1>&2
	
	BillingAllocationFile="${ProjectPath}/${BillingAllocationFileName}"
	if [ ! -e "$BillingAllocationFile" ]
	then
		echo "${ProjectPath} : '${BillingAllocationFile}' not found. Skipping" 1>&2
		continue
	fi

	AllocationInfoJson=$(csvjson --stream "$BillingAllocationFile" | jq -s --argjson ProjectPath "\"${ProjectPath}\"" '{ ($ProjectPath): { "AllocationInfo": . }}' )

	TotalAllocationPercent=$(echo "$AllocationInfoJson" | jq '.[] | [ .AllocationInfo[].AllocationPercent ]| add'| sed 's/\.0$//')
	if [ "$TotalAllocationPercent" != '100' ]
	then
		AllocationPercents=$(echo "$AllocationInfoJson" | jq '[ .[] | .AllocationInfo[].AllocationPercent ] | join(" + ") ' | sed 's/\.0//g')
		echo "${ProjectPath} : Allocation Percents: ${AllocationPercents} != 100 : Skipping" 1>&2
		continue
	fi

	echo "$AllocationInfoJson"
    done < <(jq -r 'to_entries[] | .key' "$PmacsProjectMetricsJsonFile") | jq -s 'add'
}

function totalPmacsStoragePools {
    local ProjectItemizedPmacsStorageJsonFile="$1"

    jq '
          (
	      reduce .[] as $p (
                  {};
                  reduce ($p.TerabytesUsed | to_entries[]) as $e (
                      .;
                      .[$e.key] += $e.value
                  )
              )
          )
          +
          {
              ProjectCount: length
          }
    ' "$ProjectItemizedPmacsStorageJsonFile"
}

