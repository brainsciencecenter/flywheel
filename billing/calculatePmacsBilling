#      "Backedupbscfiles3": 0,
#      "NotBackedupGPFS": 0,
#      "NotBackedupbscfiles1": 0,
#      "NotBackedupbscfiles2": 0,
#      "NotBackedupbscfiles3": 0
#    },
#    "AllocationInfo": [
#      {
#        "AllocationPercent": 30.0,
#        "iLabServiceRequestId": 4334346.0,
#        "BenNumber": "400-4452-4-571661-5340-2810-2992",
#        "FundName": "R01 AG056014",
#        "BaName": "Bonna Mean",
#        "BaEmail": "Bonna.Mean@pennmedicine.upenn.edu"
#      },
#      {
#        "AllocationPercent": 30.0,
#        "iLabServiceRequestId": 4329982.0,
#        "BenNumber": "400-4452-4-589891-5340-2810-2992",
#        "FundName": "R01 AG069474",
