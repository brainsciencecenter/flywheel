#!/bin/bash

CmdName=$(basename "$0")
Syntax="${CmdName} [-D][-d]{-i Id2LabeleJsonFile}[-r][-t] {CachedJsonFile}"

#
# -D debug
# -d run dcm2niix when needed
# -i Id2LabelJsonFile
# -r generate report
# -t do the actual tagging
#
# cd Fw2InddCache
# tagNaccScPreferredT1sV2 -rtu dwolklab-NACC-SC-CachedFwAcquisitions.json
#

CmdDir=$(dirname $(which "$CmdName"))
FwDir=$(dirname "$CmdDir")
FwLibDir="${FwDir}/lib"

TagCutOffDate='2025-07-09'
Debug=false

TmpDir="${TMPDIR:=/tmp}"
[ -e "$TmpDir" ] || mkdir -p "$TmpDir"


while getopts 'Ddi:rt' arg
do
    case "$arg" in
	D|d|i|r|t)
	    eval "opt_${arg}='${OPTARG:=1}'"
	    ;;
    esac
done

shift $(( "$OPTIND" - 1 )) 

GroupProjectCachedJsonFile="$1"
if [ -z "$GroupProjectCachedJsonFile" ]
then
    echo "${CmdName} : Missing CachedJsonFile" 1>&2
    echo "$Syntax" 1>&2
    exit 1
fi

if [ ! -e "$GroupProjectCachedJsonFile" ]
then
    echo "${CmdName} : Can not open '${GroupProjectCachedJsonFile}'" 1>&2
    echo "$Syntax" 1>&2
    exit 2
fi

Id2LabelJsonFile="$opt_i"
if [ -z "$Id2LabelJsonFile" ]
then
    echo "${CmdName} : Missing Id2LabelJsonFile" 1>&2
    echo "$Syntax" 1>&2
    exit 3
fi

if [ ! -e "$Id2LabelJsonFile" ]
then
    echo "${CmdName} : Can not open '${Id2LabelJsonFile}'" 1>&2
    echo "$Syntax" 1>&2
    exit 4
fi

[ -n "$opt_D" ] && Debug=true

Jq='
  .label as $AcquisitionLabel
| ._id as $AcquisitionId
| .created as $CreatedDate
| .parents.session as $SessionId
| $Id2Label[][$SessionId] as $SessionLabel
| $Id2Label[][.parents.subject] as $SubjectLabel
| $Id2Label[][.parents.project] as $ProjectLabel
| $Id2Label[][.parents.group] as $GroupLabel
| .files[]
    | .file_id as $FileId
    | .name as $FileName
    | .type as $FileType
    | ( .tags | sort | join(":") ) as $FileTags
    | .modality as $FileModality
    | .classification.Measurement[0] as $ClassificationMeasurement
    | if ($Debug)
      then
          debug("Tags: " + (.tags | join(":")) )
      else
          .
      end
    | ([ $GroupLabel, $ProjectLabel, $SubjectLabel, $SessionLabel, $AcquisitionLabel, $FileName ] | join("/") )as $FilePath
    | {
           "SessionId": $SessionId
	 , "SessionLabel": $SessionLabel
 	 , "CreatedDate": $CreatedDate
         , "AcquisitionId": $AcquisitionId
	 , "AcquisitionLabel": $AcquisitionLabel
 	 , "FileName": $FileName
 	 , "FileId": $FileId
 	 , "FileType": $FileType
 	 , "FileModality": $FileModality
 	 , "ClassificationMeasurement": $ClassificationMeasurement
         , "FileTags": $FileTags
	 , "FilePath": $FilePath
       }

'

AcquisitionSequenceJsonFile="${TmpDir}/AcquisitionsSequence.json"
jq --argjson Debug "$Debug" --slurpfile 'Id2Label' "$Id2LabelJsonFile" "$Jq" "$GroupProjectCachedJsonFile" > "$AcquisitionSequenceJsonFile"

GroupBySessionJq='
    sort_by(.SessionId)
  | group_by(.SessionId)
  | map({
      SessionId: .[0].SessionId,
      SessionLabel: .[0].SessionLabel,
      CreatedDate: .[0].CreatedDate,
      Acquisitions:
      (
        sort_by(.AcquisitionId)
        | group_by(.AcquisitionId)
        | map({
            AcquisitionId: .[0].AcquisitionId,
            AcquisitionLabel: .[0].AcquisitionLabel,
            Files: map({
              FileId,
              FileName,
              FileType,
              FileModality,
              ClassificationMeasurement,
	      FileTags,
              FilePath
            })
          })
      )})
'

SessionAcquisitionJsonFile="${TmpDir}/SessionAcquisition.json"
jq -r -s "$GroupBySessionJq" "$AcquisitionSequenceJsonFile" > "$SessionAcquisitionJsonFile"

#
# Accelerated Sagittal MPRAGE_1
# Accelerated Sagittal MPRAGE_18_18
# Accelerated Sagittal MPRAGE_2_2
# are also counted
#
TagDeterminationJq='
      include "FwLib";

       .[]
      | "T1_3D_0.8x0.8x0.8$" as $T1_Label
      | "T1_3D_0.8x0.8x0.8_ND$" as $T1_Nd_Label
      | "Accelerated Sagittal MPRAGE.*$" as $AcceleratedSagittalLabel
      | "ABCD_T1w_MPR_vNav RMS" as $AbcdT1RmsLabel
      | ( [ .Acquisitions[].AcquisitionLabel ] | join(":") ) as $AcquisitionLabels
      | if (isClaritiSession(.SessionLabel))
      then
         if (createdDate(.) >= "'"$TagCutOffDate"'") 
	 then
             "PreferredT1-'"$TagCutOffDate"'" as $Tag
|             if (hasAcquisition($AbcdT1RmsLabel)) 
	     then
                 markForTagging($AbcdT1RmsLabel; $Tag) 
             else
	         if (hasAcquisition($AcceleratedSagittalLabel)) 
		 then
                     markForTagging($AcceleratedSagittalLabel; $Tag)
                 else 
                     if ($Debug)
                     then
                         debug("CLARiTI Session \(.SessionLabel) after cutoff missing Acquisitions \($AcquisitionLabels)")
                     else
                          empty
                     end
                 end
	     end
         else
             "PreferredT1" as $Tag
|             if hasAcquisition($T1_Nd_Label) 
	     then
                 markForTagging($T1_Nd_Label; $Tag)
             else
                 if (hasAcquisition($AcceleratedSagittalLabel))
		 then
                     markForTagging($AcceleratedSagittalLabel; $Tag)
		 else
                     if ($Debug)
                     then
                         debug("CLARiTI Session \(.SessionLabel) before cutoff missing Acquisitions \($AcquisitionLabels)")
                     else
                         empty
                     end
                 end
	     end
         end
     else
        if (createdDate(.) >= "'"$TagCutOffDate"'")
        then
             "PreferredT1-'"$TagCutOffDate"'" as $Tag
|             if (hasAcquisition($T1_Label))
	     then
                 markForTagging($T1_Label; $Tag)
             else
                 if (hasAcquisition($AcceleratedSagittalLabel))
		 then
                     markForTagging($AcceleratedSagittalLabel; $Tag)
                 else
                     if ($Debug)
                     then
                         debug("non-CLARiTI Session \(.SessionLabel) after cutoff missing Acquisitions \($AcquisitionLabels)")
                     else
                         empty
                     end
		 end
	     end
         else
             "PreferredT1" as $Tag
|             if (hasAcquisition($T1_Nd_Label))
	      then
                 markForTagging($T1_Nd_Label; $Tag)
             else
	         if (hasAcquisition($AcceleratedSagittalLabel))
		 then
                     markForTagging($AcceleratedSagittalLabel; $Tag)
                 else
                     if ($Debug)
                     then
                         debug("non-CLARiTI Session \(.SessionLabel) before cutoff missing Acquisitions \($AcquisitionLabels)")
                     else
                         empty
                     end
                 end
             end
         end
     end
'

FileTaggedStatusJsonFile="${TmpDir}/FileTaggedStatus.json"
jq -L "$FwLibDir" --argjson Debug "$Debug" "$TagDeterminationJq" "$SessionAcquisitionJsonFile" > "$FileTaggedStatusJsonFile"

if [ -n "$opt_d" ]
then
    for FileId in $(jq -r 'select(.RunDcm2Niix) | .FileIdToTag' "$FileTaggedStatusJsonFile")
    do
	fwRunGear -w -g dcm2niix -i dcm2niix_input "$FileId"
    done
fi

#
# Filter out dicom files which need to be converted to nifti.  We'll
# tag these the next time this program is run
#
FilesToTagJsonFile="${TmpDir}/FilesToTagJsonFile.json"
jq '.NewTag as $NewTag | select((.RunDcm2Niix == false) and (.FileTags | split(":") | (any($NewTag) | not)))' "$FileTaggedStatusJsonFile" > "$FilesToTagJsonFile"

GroupByTagJq='
    group_by(.NewTag)
    | map({
        NewTag: .[0].NewTag,
        FilesToTag: map({
          FileIdToTag,
          FilePath
        })
      })
      | .[]
'
GroupedFilesToTagJsonFile="${TmpDir}/GroupedFilesToTag.json"
jq -s "$GroupByTagJq" "$FilesToTagJsonFile" > "$GroupedFilesToTagJsonFile"

if [ -n "$opt_t" ]
then
    while read Tag
    do
	FileIdsToTag=$(jq -r --argjson Tag '"'"$Tag"'"' 'select(.NewTag == $Tag) | .FilesToTag[].FileIdToTag' "$GroupedFilesToTagJsonFile")
	[ -n "$FileIdsToTag" ] && fwTag -up -t "$Tag" $FileIdsToTag
    done < <(jq -r '.NewTag' "$GroupedFilesToTagJsonFile")
fi

if [ -n "$opt_r" ]
then
    Now=$(date '+%Y-%m-%dT%H:%M:%d%z')
    echo "NACC-SC Preferred T1 Tag Report ${Now}"
    echo ""	

    TotalFilesToConvert=$(jq -r 'select(.RunDcm2Niix) | .FileIdToTag' "$FileTaggedStatusJsonFile" | wc -l)
    echo "${TotalFilesToConvert} file(s) to run dcm2niix on"

    if [ "$TotalFilesToConvert" -gt 0 ]
    then
	while read FilePathToConvert
	do
		echo "$FilePathToConvert" | sed 's/^/	/'
	done < <(jq -r 'select(.RunDcm2Niix) | .FilePath' "$FileTaggedStatusJsonFile")
    fi
    echo

    TotalFilesToTag=$(jq '.FilesToTag[].FileIdToTag' "$GroupedFilesToTagJsonFile" | wc -l)
    if [ "$TotalFilesToTag" -gt 0 ]
    then
	echo "${TotalFilesToTag} files to tag"
	echo
	while read Tag
	do
	    NumFilesForTag=$(jq -r --argjson Tag "\"${Tag}\"" 'select(.NewTag == $Tag) | .FilesToTag[].FileIdToTag' "$GroupedFilesToTagJsonFile" | wc -l)
	    echo "${Tag} (${NumFilesForTag})"

	    if [ "$NumFilesForTag" -gt 0 ]
	    then
	        while read FilePath
	        do
		    echo "$FilePath" | sed 's/^/	/'
    	        done < <(jq -r --argjson Tag "\"${Tag}\"" 'select(.NewTag == $Tag) | .FilesToTag[].FilePath' "$GroupedFilesToTagJsonFile")
            fi
	    echo	        

	done < <(jq -r '.NewTag' "$GroupedFilesToTagJsonFile")
    else
	echo "No files to tag"
    fi
fi



