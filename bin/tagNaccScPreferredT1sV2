#!/bin/bash

CmdName=$(basename "$0")
CmdDir=$(dirname $(which "$CmdName"))
FwDir=$(dirname "$CmdDir")
FwLibDir="${FwDir}/lib"

Jq='
  .label as $AcquisitionLabel
| ._id as $AcquisitionId
| .created as $CreatedDate
| .parents.session as $SessionId
| $Id2Label[][$SessionId] as $SessionLabel
| $Id2Label[][.parents.subject] as $SubjectLabel
| $Id2Label[][.parents.project] as $ProjectLabel
| $Id2Label[][.parents.group] as $GroupLabel
| .files[]
    | .file_id as $FileId
    | .name as $FileName
    | .type as $FileType
    | .modality as $FileModality
    | .classification.Measurement[0] as $ClassificationMeasurement
    | ([ $GroupLabel, $ProjectLabel, $SubjectLabel, $SessionLabel, $AcquisitionLabel, $FileName ] | join("/") )as $FilePath
    | {
           "SessionId": $SessionId
	 , "SessionLabel": $SessionLabel
 	 , "CreatedDate": $CreatedDate
         , "AcquisitionId": $AcquisitionId
	 , "AcquisitionLabel": $AcquisitionLabel
 	 , "FileName": $FileName
 	 , "FileId": $FileId
 	 , "FileType": $FileType
 	 , "FileModality": $FileModality
 	 , "ClassificationMeasurement": $ClassificationMeasurement
 	 , "FilePath": $FilePath
       }

'
Id2LabelJsonFile='dwolklab/NACC-SC/Id2Labels.json'
AcquisitionSequenceJsonFile='/tmp/AcquisitionsSequence.json'
if [ -n "$Force" ] || [ ! -e "$AcquisitionSequenceJsonFile" ] || [ ! -s "$AcquisitionSequenceJsonFile" ]
then
	jq -r --slurpfile 'Id2Label' "$Id2LabelJsonFile" "$Jq" "$1" > "$AcquisitionSequenceJsonFile"
fi

GroupBySessionJq='
    sort_by(.SessionId)
  | group_by(.SessionId)
  | map({
      SessionId: .[0].SessionId,
      SessionLabel: .[0].SessionLabel,
      CreatedDate: .[0].CreatedDate,
      Acquisitions:
      (
        sort_by(.AcquisitionId)
        | group_by(.AcquisitionId)
        | map({
            AcquisitionId: .[0].AcquisitionId,
            AcquisitionLabel: .[0].AcquisitionLabel,
            Files: map({
              FileId,
              FileName,
              FileType,
              FileModality,
              ClassificationMeasurement,
              FilePath
            })
          })
      )})
'

SessionAcquisitionJsonFile='/tmp/SessionAcquisition.json'
if [ -n "$Force" ] || [ ! -e "$SessionAcquisitionJsonFile" ] || [ ! -s "$SessionAcquisitionJsonFile" ]
then
    jq -r -s "$GroupBySessionJq" "$AcquisitionSequenceJsonFile" > "$SessionAcquisitionJsonFile"
fi

#
# *** What about
# Accelerated Sagittal MPRAGE_1
# Accelerated Sagittal MPRAGE_18_18
# Accelerated Sagittal MPRAGE_2_2

TagDeterminationJq='
      include "FwLib";

       .[]
      | "T1_3D_0.8x0.8x0.8$" as $T1_Label
      | "T1_3D_0.8x0.8x0.8_ND$" as $T1_Nd_Label
      | "Accelerated Sagittal MPRAGE$" as $AcceleratedSagittalLabel
      | "Accelerated Sagittal MPRAGE \\(MSV21\\)$" as $AcceleratedSagittalMsv21Label
      | "ABCD_T1w_MPR_vNav RMS" as $AbcdT1RmsLabel
      | ( [ .Acquisitions[].AcquisitionLabel ] | join(":") ) as $AcquisitionLabels
      | if (isClaritiSession(.SessionLabel))
      then
         if (createdDate(.) >= "2025-07-09") 
	 then
             "PreferredT1-2025-07-09" as $Tag
|             if (hasAcquisition($AbcdT1RmsLabel)) 
	     then
                 markForTagging($AbcdT1RmsLabel; $Tag) 
             else
	         if (hasAcquisition($AcceleratedSagittalLabel)) 
		 then
                     markForTagging($AcceleratedSagittalLabel; $Tag)
                 else 
                     debug("CLARiTI Session \(.SessionLabel) after cutoff missing Acquisitions \($AcquisitionLabels)") | empty
                 end
	     end
         else
             "PreferredT1" as $Tag
|             if hasAcquisition($T1_Nd_Label) 
	     then
                 markForTagging($T1_Nd_Label; $Tag)
             else
                 if (hasAcquisition($AcceleratedSagittalLabel))
		 then
                     markForTagging($AcceleratedSagittalLabel; $Tag)
		 else
                     debug("CLARiTI Session \(.SessionLabel) before cutoff missing Acquisitions \($AcquisitionLabels)") | empty
                 end
	     end
         end
     else
        if (createdDate(.) >= "2025-07-09")
        then
             "PreferredT1-2025-07-09" as $Tag
|             if (hasAcquisition($T1_Label))
	     then
                 markForTagging($T1_Label; $Tag)
             else
                 if (hasAcquisition($AcceleratedSagittalMsv21Label))
		 then
                     markForTagging($AcceleratedSagittalMsv21Label; $Tag)
                 else
                     debug("non-CLARiTI Session \(.SessionLabel) after cutoff missing Acquisitions \($AcquisitionLabels)") | empty
		 end
	     end
         else
             "PreferredT1" as $Tag
|             if (hasAcquisition($T1_Nd_Label))
	      then
                 markForTagging($T1_Nd_Label; $Tag)
             else
	         if (hasAcquisition($AcceleratedSagittalLabel))
		 then
                     markForTagging($AcceleratedSagittalLabel; $Tag)
                 else
                     debug("non-CLARiTI Session \(.SessionLabel) before cutoff missing Acquisitions \($AcquisitionLabels)") | empty
                 end
             end
         end
     end
'


jq -r -L "$FwLibDir" "$TagDeterminationJq" "$SessionAcquisitionJsonFile"
